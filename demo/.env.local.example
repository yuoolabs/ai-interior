# Copy this file to .env.local and fill in your real values.
# Server will auto-load .env.local on startup.

# Model config
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key
# MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Adapter runtime mode: mock | real | ui_only
MICROPAGE_ADAPTER_MODE=ui_only

# Required only for real API mode
# MICROPAGE_API_BASE=https://your-micropage-api.example.com
# MICROPAGE_API_TOKEN=your_token
# MICROPAGE_API_PROFILE_FILE=./backend/config/micropage-api-profile.real-template.json

# Auto publish policy
ENABLE_REAL_AUTO_PUBLISH=false
# AUTOPUBLISH_TENANT_ALLOWLIST=tenant_a,tenant_b
